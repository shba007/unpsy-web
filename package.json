{
  "name": "unpsy-web",
  "version": "0.7.10",
  "description": "A psychoanalytical web tool for diverse assessments and automatic analysis with a built-in scanner",
  "author": "Shirsendu Bairagi <shirsendu2001@gmail.com>",
  "license": "LGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/Algostract/unpsy-web.git"
  },
  "type": "module",
  "private": true,
  "engines": {
    "node": "^20.15.0 || ^22.11.0",
    "pnpm": "^9.15.0 || ^10.2.0",
    "bun": "^1.2.9"
  },
  "packageManager": "bun@1.3.9",
  "scripts": {
    "prepare": "husky || true",
    "postinstall": "nuxt prepare",
    "dev": "nuxt dev",
    "detect": "gitleaks git --verbose",
    "lint": "eslint . --fix",
    "format": "prettier . --write",
    "test:load": "k6 run tests/load.test.ts",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "clean": "nuxt cleanup",
    "start": "node .output/server/index.mjs",
    "docker:build": "docker build --build-arg VERSION=dev --build-arg BUILD_TIME=now -t unpsy:dev .",
    "docker:start": "docker run --detach --name unpsy-dev --env-file .env.prod -p 4000:3000 unpsy:dev",
    "tunnel": "untun tunnel --port 4000 http://localhost:4000"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "@notionhq/client": "^5.9.0",
    "@nuxt/eslint": "^1.15.1",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "0.11.5",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@nuxtjs/seo": "^3.4.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@pinia/nuxt": "^0.11.3",
    "@splidejs/splide-extension-grid": "^0.4.1",
    "@unhead/vue": "^2.1.4",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "nuxt": "^4.3.1",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt-splide": "1.1.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.28",
    "vue-router": "^5.0.3",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/k6": "^1.6.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.1",
    "happy-dom": "^20.7.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "playwright-core": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "untun": "^0.1.3",
    "vitest": "^4.0.18"
  }
}
